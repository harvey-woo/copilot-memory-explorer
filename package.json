{
  "name": "copilot-memory-explorer",
  "displayName": "%ext.displayName%",
  "description": "%ext.description%",
  "version": "0.1.4",
  "publisher": "cat5th",
  "icon": "media/marketplace-icon.png",
  "l10n": "./l10n",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/harvey-woo/copilot-memory-explorer"
  },
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "AI",
    "Visualization",
    "Other"
  ],
  "keywords": [
    "copilot",
    "memory",
    "explorer",
    "github-copilot",
    "memory-management",
    "visualization"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "memory-explorer-sidebar",
          "title": "%memoryExplorer.viewContainer.title%",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "memory-explorer-sidebar": [
        {
          "id": "memoryExplorer.projectView",
          "name": "%memoryExplorer.projectView.name%",
          "type": "tree"
        },
        {
          "id": "memoryExplorer.userView",
          "name": "%memoryExplorer.userView.name%",
          "type": "tree"
        }
      ],
      "memory-preview-panel": [
        {
          "id": "memoryExplorer.previewView",
          "name": "%memoryPreview.view.name%",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "memoryBoard.refresh",
        "title": "%cmd.refresh%",
        "icon": "$(refresh)"
      },
      {
        "command": "memoryBoard.openFile",
        "title": "%cmd.openFile%"
      },
      {
        "command": "memoryBoard.copyPath",
        "title": "%cmd.copyPath%"
      },
      {
        "command": "memoryBoard.revealInOs",
        "title": "%cmd.revealInOs%"
      },
      {
        "command": "memoryBoard.toggleSort",
        "title": "%cmd.toggleSort%",
        "icon": "$(sort-precedence)"
      },
      {
        "command": "memoryBoard.deleteEntry",
        "title": "%cmd.deleteEntry%",
        "icon": "$(trash)"
      },
      {
        "command": "memoryBoard.newMemory",
        "title": "%cmd.newMemory%",
        "icon": "$(new-file)"
      },
      {
        "command": "memoryBoard.refreshUser",
        "title": "%cmd.refreshUser%",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "memoryBoard.refresh",
          "group": "navigation",
          "when": "view == memoryExplorer.projectView"
        },
        {
          "command": "memoryBoard.toggleSort",
          "group": "navigation",
          "when": "view == memoryExplorer.projectView"
        },
        {
          "command": "memoryBoard.newMemory",
          "group": "navigation",
          "when": "view == memoryExplorer.projectView"
        },
        {
          "command": "memoryBoard.refreshUser",
          "group": "navigation",
          "when": "view == memoryExplorer.userView"
        }
      ],
      "view/item/context": [
        {
          "command": "memoryBoard.copyPath",
          "when": "view == memoryExplorer.projectView && viewItem == 'file'"
        },
        {
          "command": "memoryBoard.revealInOs",
          "when": "view == memoryExplorer.projectView && (viewItem == 'file' || viewItem == 'directory' || viewItem == 'session')"
        },
        {
          "command": "memoryBoard.openFile",
          "when": "view == memoryExplorer.projectView && viewItem == 'file'"
        },
        {
          "command": "memoryBoard.newMemory",
          "when": "view == memoryExplorer.projectView && (viewItem == 'directory' || viewItem == 'session')"
        },
        {
          "command": "memoryBoard.deleteEntry",
          "when": "view == memoryExplorer.projectView && (viewItem == 'file' || viewItem == 'directory' || viewItem == 'session')"
        },
        {
          "command": "memoryBoard.copyPath",
          "when": "view == memoryExplorer.userView && viewItem == 'file'"
        },
        {
          "command": "memoryBoard.revealInOs",
          "when": "view == memoryExplorer.userView && (viewItem == 'file' || viewItem == 'directory')"
        },
        {
          "command": "memoryBoard.openFile",
          "when": "view == memoryExplorer.userView && viewItem == 'file'"
        },
        {
          "command": "memoryBoard.deleteEntry",
          "when": "view == memoryExplorer.userView && (viewItem == 'file' || viewItem == 'directory')"
        }
      ]
    }
  },
  "scripts": {
    "lint": "eslint src/",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.96.0",
    "@vscode/vsce": "^3.0.0",
    "eslint": "^9.0.0"
  }
}
